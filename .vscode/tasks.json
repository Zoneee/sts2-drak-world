{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build: Release",
            "type": "shell",
            "command": "bash",
            "args": [
                "./scripts/build-release.sh"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": false
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build: Debug",
            "type": "shell",
            "command": "bash",
            "args": [
                "./scripts/build-debug.sh"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "Deploy: Release Runtime",
            "type": "shell",
            "command": "bash",
            "args": [
                "./scripts/deploy-release.sh"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": false
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Deploy: Debug Runtime",
            "type": "shell",
            "command": "bash",
            "args": [
                "./scripts/deploy-debug.sh"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": false
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Build + Deploy: Release",
            "type": "shell",
            "command": "bash",
            "args": [
                "./scripts/build-deploy-release.sh"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "echo": true
            }
        },
        {
            "label": "Build + Deploy: Debug",
            "type": "shell",
            "command": "bash",
            "args": [
                "./scripts/build-deploy-debug.sh"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "echo": true
            }
        },
        {
            "label": "Clean Build",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "clean",
                "src/STS2_Discard_Mod.csproj"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Attach Debugger: Godot",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Write-Host '💡 Launching VS Code debugger...\\r\\nSteps:\\r\\n1. Click Debug → Attach to Process\\r\\n2. Search for: Godot.exe\\r\\n3. Click Attach\\r\\n\\r\\n⏳ This will give you breakpoint debugging support!' -ForegroundColor Cyan"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Build + Deploy + Attach Prep: Debug",
            "type": "shell",
            "command": "bash",
            "args": [
                "./scripts/build-deploy-debug.sh"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": false
            }
        }
    ]
}