<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    
    <!-- Assembly metadata -->
    <AssemblyName>STS2_Discard_Mod</AssemblyName>
    <RootNamespace>DiscardMod</RootNamespace>
    <Version>0.1.0</Version>
    
    <!-- Build output -->
    <OutputPath>bin\$(Configuration)\</OutputPath>
    <PublishDir>dist\</PublishDir>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    
    <!-- Disable auto-generated assembly info to avoid conflicts -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <!-- NuGet Package Dependencies -->
  <ItemGroup>
    <!-- Harmony: Runtime patching for discard event detection -->
    <PackageReference Include="HarmonyX" Version="2.10.2" />
  </ItemGroup>

  <!-- STS2 Game DLL Reference -->
  <!-- STEP 1: Copy sts2.dll from game folder to lib/sts2.dll (see lib/README.md) -->
  <!-- STEP 2: Uncomment the block below -->
  <!-- STEP 3: Delete src/Stubs/ModInitializerStub.cs -->
  <!-- STEP 4: Uncomment the 'using MegaCrit.*' lines in Main.cs and Logger.cs -->
  <!--
  <ItemGroup>
    <Reference Include="sts2">
      <HintPath>..\lib\sts2.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
  -->

  <!-- Define stub constant when sts2.dll is NOT available -->
  <PropertyGroup Condition="!Exists('$(MSBuildProjectDirectory)/../lib/sts2.dll')">
    <DefineConstants>$(DefineConstants);STS2_NOT_AVAILABLE</DefineConstants>
  </PropertyGroup>

</Project>
